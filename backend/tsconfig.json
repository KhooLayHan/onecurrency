{
  "extends": "../tsconfig.base.json",

  "compilerOptions": {
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "outDir": "dist",
    "noEmit": false,
    "baseUrl": "src",
    "paths": {
      "@/*": ["./*"],
      "@/common/*": ["../../packages/common/*"]
    },
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules"]
}
