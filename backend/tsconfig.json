{
  "extends": "../tsconfig.base.json",

  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules"],
  "compilerOptions": {
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "outDir": "dist",
    "noEmit": false,
    "paths": {
      "@/*": ["./*"],
      "@/common/*": ["../../packages/common/*"]
    }
  }
}
