{
  "name": "onecurrency-backend",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "DB_MIGRATION=true bun --env-file=.env run src/migration.ts",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:check": "drizzle-kit check",
    "db:up": "drizzle-kit up",
    "db:studio": "drizzle-kit studio",
    "db:seed": "DB_SEEDING=true bun run src/seeding.ts",
    "db:prod:generate": "NODE_ENV=production bun --env-file=.env.production run drizzle-kit generate",
    "db:prod:migrate": "NODE_ENV=production DB_MIGRATION=true bun --env-file=.env.production run src/migration.ts",
    "db:prod:seed": "NODE_ENV=production DB_SEEDING=true bun --env-file=.env.production run src/seeding.ts"
  },
  "dependencies": {
    "@hono/standard-validator": "^0.2.2",
    "@neondatabase/serverless": "^1.0.2",
    "@orpc/openapi": "^1.13.13",
    "@orpc/server": "^1.13.13",
    "@scalar/hono-api-reference": "^0.10.6",
    "@t3-oss/env-core": "^0.13.10",
    "better-auth": "^1.4.20",
    "drizzle-orm": "^1.0.0-beta.15-859cf75",
    "hono": "^4.11.9",
    "http-status-codes": "^2.3.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "stripe": "^20.4.1",
    "viem": "^2.47.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@types/bun": "latest",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^1.0.0-beta.15-859cf75"
  }
}
